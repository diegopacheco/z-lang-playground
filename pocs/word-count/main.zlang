let sentence: "the cat sat on the mat the cat"
let words: sentence.split(" ")
log("total words: " ++ words.length)
let counts: [:]
let i: 0
loop {
    if i >= words.length { break }
    let w: words[i]
    if counts[w] = undefined {
        counts[w]: 1
    } else {
        counts[w]: counts[w] + 1
    }
    i: i + 1
}
log(counts)
