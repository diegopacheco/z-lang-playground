let sorted: [2, 5, 8, 12, 16, 23, 38, 56, 72, 91]
def linearSearch: func(arr, target) {
    let i: 0
    loop {
        if i >= arr.length { return -1 }
        if arr[i] = target { return i }
        i: i + 1
    }
}
log(linearSearch(sorted, 23))
log(linearSearch(sorted, 72))
log(linearSearch(sorted, 99))
log(linearSearch(sorted, 2))
