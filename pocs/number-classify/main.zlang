let nums: [-5, 0, 3, -2, 7, -1, 4, 0]
let pos: 0
let neg: 0
let zeros: 0
let i: 0
loop {
    if i >= nums.length { break }
    if nums[i] > 0 {
        pos: pos + 1
    } else if nums[i] < 0 {
        neg: neg + 1
    } else {
        zeros: zeros + 1
    }
    i: i + 1
}
log("positive: " ++ pos)
log("negative: " ++ neg)
log("zeros: " ++ zeros)
